# ============================================================================
# PRISM-benchmarks — public config (safe to commit)
# ============================================================================
# Included by the Makefile (`include bench.env; export`). All values are plain
# strings; override on the CLI, e.g.  make render SCENES="a b" TRAJ=synthetic_spline
# ============================================================================

# ── Hardware label (stamped into every perf table; benchmark on the 6000 only) ──
HW_ID       := RTX PRO 6000
DEVICE      := cuda

# ── Submodule pins (URL + exact commit). `make init` clones + checks these out. ──
PRISM_URL   := https://github.com/zRafaF/PRISM-VGGT
PRISM_REF   := HEAD
PI3_URL     := https://github.com/yyfz/Pi3
PI3_REF     := 9fa3ddb3f8d53041f8b2738df404f62223bbaa7b
VGGTSLAM_URL:= https://github.com/MIT-SPARK/VGGT-SLAM
VGGTSLAM_REF:= 35327ac28b7d193df9ccc39ba6346052bb6f1207
MAPANY_URL  := https://github.com/facebookresearch/map-anything
MAPANY_REF  := c845b8f4f6cde0c20aecd87573656c3f69f5b2b0
LASER_URL   := https://github.com/neu-vi/LASER
LASER_REF   := 7adbb7d5c1558f0446398310f31ee92fb4bc2de1

# ── PanoVGGT weights ──
# The original HF repo (YijingGuo/PanoVGGT) went private (403). Use a mirror bucket.
PANOVGGT_WEIGHTS_URL := https://huggingface.co/buckets/DoninhaD/PanoVGGT-bucket/resolve/model.pt?download=true

# ── Config file every script reads ──
CONFIG      := config.yaml

# ── Default run parameters (mirror the live PRISM / report config) ──
SCENES      :=
TRAJ        := all
WINDOW      := 16
OVERLAP     := 4
VOXEL       := 0.02
MAX_DEPTH   := 4.5
FACE_SIZE   := 768

# ── uv entrypoint for each isolated method env ──
UV          := uv
